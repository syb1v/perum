# PERUM — продакшн .env (скопировать в deploy/.env.prod, не коммитить).
# Деплой по docs/RUNBOOK.md. Образы — из GHCR (публикуются release-workflow по тегу).

ENVIRONMENT=prod

# Базовые образы (postgres/redis/caddy). В РФ — зеркало.
IMAGE_REGISTRY=mirror.gcr.io

# Образы приложений (из GHCR; <owner> = github.repository_owner).
CORE_IMAGE=ghcr.io/syb1v/perum-core:latest
WEB_IMAGE=ghcr.io/syb1v/perum-web:latest
# TENANT_IMAGE = образ школьного стека; должен совпадать с текущим релизом в ядре.
TENANT_IMAGE=ghcr.io/syb1v/perum-tenant:1.0.0

# Секреты — СГЕНЕРИРОВАТЬ (openssl rand -hex 32). НЕ использовать dev-значения.
SECRET_KEY=__CHANGE_ME__
CONTROL_DB_PASSWORD=__CHANGE_ME__

# Первый platform_admin — задать надёжный пароль (НЕ admin/admin).
BOOTSTRAP_ADMIN_LOGIN=admin
BOOTSTRAP_ADMIN_PASSWORD=__CHANGE_ME__

# Домены и TLS.
PUBLIC_BASE_DOMAIN=perum.ru
ACME_EMAIL=ops@perum.ru
CONTROL_PLANE_URL=http://perum_core:3000

# Observability (Grafana).
GRAFANA_USER=admin
GRAFANA_PASSWORD=__CHANGE_ME__
