#!/usr/bin/env bash
# =============================================================================
# PERUM Node Bootstrap Script
# Node: {{ node_name }}
# Organization: {{ org_slug }}
# Generated: {{ generated_at }}
# =============================================================================
set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log() { echo -e "${GREEN}[PERUM]${NC} $*"; }
warn() { echo -e "${YELLOW}[PERUM]${NC} $*"; }
error() { echo -e "${RED}[PERUM]${NC} $*" >&2; }

# Configuration
NODE_NAME="{{ node_name }}"
ENROLLMENT_TOKEN="{{ enrollment_token }}"
CORE_URL="{{ core_url }}"
ORG_SLUG="{{ org_slug }}"
RELEASE_TAG="{{ release_tag }}"
INSTALL_DIR="/opt/perum-node"

# =============================================================================
# 1. System Check
# =============================================================================
log "Step 1/12: Checking system requirements..."

if [[ $EUID -ne 0 ]]; then
    error "This script must be run as root"
    exit 1
fi

if ! command -v lsb_release &> /dev/null; then
    warn "lsb_release not found, skipping OS version check"
else
    OS_VERSION=$(lsb_release -rs)
    if [[ "$OS_VERSION" < "22.04" ]]; then
        warn "Ubuntu 22.04+ recommended (found $OS_VERSION)"
    fi
fi

TOTAL_RAM_MB=$(free -m | awk '/^Mem:/{print $2}')
if [[ $TOTAL_RAM_MB -lt 1800 ]]; then
    warn "Low RAM: ${TOTAL_RAM_MB}MB (recommended: 2048MB+)"
fi

log "System check passed"

# =============================================================================
# 2. Install Docker
# =============================================================================
log "Step 2/12: Installing Docker..."

if command -v docker &> /dev/null; then
    log "Docker already installed: $(docker --version)"
else
    apt-get update -qq
    apt-get install -y -qq ca-certificates curl gnupg lsb-release

    install -m 0755 -d /etc/apt/keyrings
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
    chmod a+r /etc/apt/keyrings/docker.gpg

    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" > /etc/apt/sources.list.d/docker.list

    apt-get update -qq
    apt-get install -y -qq docker-ce docker-ce-cli containerd.io docker-compose-plugin

    systemctl enable docker
    systemctl start docker

    log "Docker installed: $(docker --version)"
fi

# =============================================================================
# 3. Configure Firewall
# =============================================================================
log "Step 3/12: Configuring firewall..."

if command -v ufw &> /dev/null; then
    ufw --force reset > /dev/null
    ufw default deny incoming
    ufw default allow outgoing
    ufw allow 22/tcp comment "SSH"
    ufw allow 80/tcp comment "HTTP"
    ufw allow 443/tcp comment "HTTPS"
    ufw --force enable
    log "UFW configured"
else
    warn "UFW not found, skipping firewall configuration"
fi

# =============================================================================
# 4. Create Installation Directory
# =============================================================================
log "Step 4/12: Creating installation directory..."

mkdir -p "$INSTALL_DIR"
cd "$INSTALL_DIR"

# =============================================================================
# 5. Write docker-compose.yml
# =============================================================================
log "Step 5/12: Writing docker-compose.yml..."

cat > docker-compose.yml << 'COMPOSE_EOF'
version: "3.9"

services:
  perum_agent:
    image: ghcr.io/perum/perum-core:{{ release_tag }}
    container_name: perum_agent
    restart: unless-stopped
    environment:
      - ROLE=org_agent
      - CORE_URL=${CORE_URL}
      - ENROLLMENT_TOKEN=${ENROLLMENT_TOKEN}
      - DATABASE_URL=postgresql+asyncpg://perum:${DB_PASSWORD}@perum_node_db:5432/perum_node
      - SECRET_KEY=${SECRET_KEY}
      - DOCKER_HOST=tcp://docker_proxy:2375
      - PUBLIC_BASE_DOMAIN=${PUBLIC_BASE_DOMAIN}
    ports:
      - "127.0.0.1:3000:3000"
    depends_on:
      - perum_node_db
      - docker_proxy
    networks:
      - perum_node

  perum_node_db:
    image: postgres:15-alpine
    container_name: perum_node_db
    restart: unless-stopped
    environment:
      - POSTGRES_USER=perum
      - POSTGRES_PASSWORD=${DB_PASSWORD}
      - POSTGRES_DB=perum_node
    volumes:
      - perum_node_data:/var/lib/postgresql/data
    networks:
      - perum_node

  docker_proxy:
    image: tecnativa/docker-socket-proxy:0.3
    container_name: perum_docker_proxy
    restart: unless-stopped
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      - CONTAINERS=1
      - IMAGES=1
      - VOLUMES=1
      - NETWORKS=1
      - EXEC=1
      - POST=1
      - AUTH=0
      - BUILD=0
      - COMMIT=0
      - CONFIGS=0
      - DISTRIBUTION=0
      - EVENTS=1
      - GRPC=0
      - INFO=0
      - NODES=0
      - PING=0
      - PLUGIN=0
      - SECRETS=0
      - SERVICES=0
      - SESSION=0
      - SWARM=0
      - SYSTEM=0
      - TASKS=1
    networks:
      - perum_node

  caddy:
    image: caddy:2-alpine
    container_name: perum_caddy
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
    environment:
      - PERUM_BASE_DOMAIN=${PUBLIC_BASE_DOMAIN}
    networks:
      - perum_node

volumes:
  perum_node_data:
  caddy_data:
  caddy_config:

networks:
  perum_node:
    driver: bridge
COMPOSE_EOF

# =============================================================================
# 6. Write .env
# =============================================================================
log "Step 6/12: Writing environment configuration..."

DB_PASSWORD=$(openssl rand -hex 16)
SECRET_KEY=$(openssl rand -hex 32)

cat > .env << ENV_EOF
CORE_URL=${CORE_URL}
ENROLLMENT_TOKEN=${ENROLLMENT_TOKEN}
ORG_SLUG=${ORG_SLUG}
DB_PASSWORD=${DB_PASSWORD}
SECRET_KEY=${SECRET_KEY}
PUBLIC_BASE_DOMAIN={{ public_base_domain }}
ENV_EOF

chmod 600 .env

# =============================================================================
# 7. Write Caddyfile
# =============================================================================
log "Step 7/12: Writing Caddyfile..."

cat > Caddyfile << 'CADDY_EOF'
{
    admin off
    auto_https on
}

:80 {
    respond "PERUM Node - OK" 200
}

:443 {
    respond "PERUM Node - OK" 200
}
CADDY_EOF

# =============================================================================
# 8. Pull Images
# =============================================================================
log "Step 8/12: Pulling Docker images..."

docker compose pull

# =============================================================================
# 9. Start Stack
# =============================================================================
log "Step 9/12: Starting PERUM node stack..."

docker compose up -d

# =============================================================================
# 10. Wait for Agent Health
# =============================================================================
log "Step 10/12: Waiting for agent to become healthy..."

MAX_WAIT=60
WAITED=0
while [[ $WAITED -lt $MAX_WAIT ]]; do
    if curl -sf http://127.0.0.1:3000/agent/health > /dev/null 2>&1; then
        log "Agent is healthy"
        break
    fi
    sleep 2
    WAITED=$((WAITED + 2))
done

if [[ $WAITED -ge $MAX_WAIT ]]; then
    error "Agent did not become healthy within ${MAX_WAIT}s"
    docker compose logs perum_agent
    exit 1
fi

# =============================================================================
# 11. Enrollment Handshake
# =============================================================================
log "Step 11/12: Performing enrollment handshake..."

ENROLL_RESPONSE=$(curl -sf -X POST "${CORE_URL}/api/enroll" \
    -H "Content-Type: application/json" \
    -d "{\"token\": \"${ENROLLMENT_TOKEN}\"}" 2>&1) || true

if echo "$ENROLL_RESPONSE" | grep -q "org_slug"; then
    log "Enrollment successful: $(echo "$ENROLL_RESPONSE" | grep -o '"org_slug":"[^"]*"')"
else
    warn "Enrollment response: $ENROLL_RESPONSE"
    warn "Manual enrollment may be required"
fi

# =============================================================================
# 12. Final Status
# =============================================================================
log "Step 12/12: Bootstrap complete!"
echo ""
echo "=============================================="
echo " PERUM Node Bootstrap Complete"
echo "=============================================="
echo " Node:         ${NODE_NAME}"
echo " Organization: ${ORG_SLUG}"
echo " Install Dir:  ${INSTALL_DIR}"
echo " Agent Port:   127.0.0.1:3000"
echo "=============================================="
echo ""
echo " Useful commands:"
echo "   cd ${INSTALL_DIR}"
echo "   docker compose ps"
echo "   docker compose logs -f"
echo "   curl http://127.0.0.1:3000/agent/health"
echo ""
log "Node is ready to receive schools from the control plane."
