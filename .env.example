# PERUM root .env example
#
# Copy to .env (gitignored) and adjust values as needed.

ENVIRONMENT=dev

# Registry prefix for base images (postgres/redis/caddy) in
# deploy/docker-compose.core.yml. Default docker.io.
# In Russia, Docker Hub layer downloads fail with EOF — set a mirror:
#   IMAGE_REGISTRY=mirror.gcr.io
# Then: IMAGE_REGISTRY=mirror.gcr.io docker compose -f deploy/docker-compose.core.yml up -d --build
# (Or configure /etc/docker/daemon.json registry-mirrors — see docs/DEPLOYMENT.md.)
IMAGE_REGISTRY=docker.io

# Used to sign JWT in the control plane and in tenant apps.
# Generate with: openssl rand -hex 32
SECRET_KEY=dev-secret-change-me

# Which tenant image new org stacks run.
# Dev: build it locally and use perum-tenant:dev (see docs/PROGRESS.md).
#   docker build -t perum-tenant:dev ./perum-tenant
# Prod: pin a released tag, e.g. ghcr.io/syb1v/perum-tenant:1.0.0
TENANT_IMAGE=perum-tenant:dev

# Base domain — used when composing <slug>.<PUBLIC_BASE_DOMAIN>.
# Dev: perum.local (add to /etc/hosts).
# Prod: perum.ru.
PUBLIC_BASE_DOMAIN=perum.local

# DNS provider used by Caddy for wildcard cert on *.<PUBLIC_BASE_DOMAIN>.
# Production: cloudflare. Dev: not used (local_certs in dev Caddyfile).
DNS_PROVIDER=cloudflare
CLOUDFLARE_API_TOKEN=

# First platform admin (admin.perum.* operator). Seeded on control-plane
# startup only if no admins exist yet. Dev default is admin/admin — CHANGE in prod.
BOOTSTRAP_ADMIN_LOGIN=admin
BOOTSTRAP_ADMIN_PASSWORD=admin

# Control plane DB (only consumed inside docker-compose.core.yml).
# In the compose file these are hardcoded to perum/perum/perum_control;
# this var is here for parity with production overrides.
CONTROL_DB_PASSWORD=perum
